<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wellness Toolkit | Ginhawa</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Ephesis&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#346739',
                        secondary: '#79AE6F',
                        bgmain: '#DED79E',
                    },
                    fontFamily: {
                        title: ['Ephesis', 'cursive'],
                    }
                }
            }
        }
    </script>
    <style>
        .breathe-circle {
            animation: breathe 8s ease-in-out infinite;
        }
        @keyframes breathe {
            0%, 100% { transform: scale(1); background-color: #79AE6F; }
            50% { transform: scale(1.5); background-color: #346739; }
        }
    </style>
</head>
<body class="bg-bgmain min-h-screen text-black font-medium overflow-x-hidden">
    <nav class="p-4 bg-white/70 backdrop-blur-md shadow-sm flex justify-between items-center px-4 md:px-8 border-b border-secondary/20 sticky top-0 z-50">
        <a href="/dashboard" class="text-2xl md:text-3xl font-black text-primary font-title shrink-0">Ginhawa</a>
        <div class="flex items-center gap-4 py-1">
            <a href="/dashboard" class="text-gray-700 hover:text-primary font-black transition text-xs md:text-sm whitespace-nowrap">Back to Dashboard</a>
        </div>
    </nav>

    <main class="p-4 md:p-8 max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-black mb-4 text-primary">Wellness Toolkit</h2>
        <p class="text-gray-700 mb-8 md:mb-12 text-base md:text-lg">Your sanctuary for mental health, study efficiency, and crisis support.</p>

        <!-- Breathing Exercise -->
        <div class="bg-white p-8 md:p-12 rounded-3xl shadow-xl border border-secondary/20 mb-8 md:mb-12 text-center">
            <h3 class="text-xl md:text-2xl font-black mb-8 text-primary">Box Breathing Exercise</h3>
            <div class="flex justify-center items-center h-48 md:h-64">
                <div class="breathe-circle w-24 h-24 md:w-32 md:h-32 rounded-full flex items-center justify-center text-white font-black text-lg md:text-xl shadow-2xl transition-all duration-500">
                    <span id="breatheText">Breathe In</span>
                </div>
            </div>
            <p class="mt-8 text-gray-500 italic font-medium text-xs md:text-base">Inhale for 4s, Hold for 4s, Exhale for 4s, Hold for 4s.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 mb-8 md:mb-12">
            <!-- Coping Strategies -->
            <div class="bg-white p-6 md:p-8 rounded-3xl border border-secondary/20 shadow-lg">
                <h3 class="text-lg md:text-xl font-black mb-6 text-primary flex items-center gap-2">
                    <span class="p-2 bg-secondary/10 rounded-lg">🧘</span> Coping Strategies
                </h3>
                <ul class="space-y-4">
                    <li class="bg-bgmain/30 p-4 rounded-xl border border-secondary/10">
                        <strong class="block text-primary text-sm md:text-base">Cognitive Reframing</strong>
                        <span class="text-xs md:text-sm text-gray-700">Instead of "I have too much to do," try "I have a lot on my plate, but I can handle one task at a time."</span>
                    </li>
                    <li class="bg-bgmain/30 p-4 rounded-xl border border-secondary/10">
                        <strong class="block text-primary text-sm md:text-base">The 5-4-3-2-1 Technique</strong>
                        <span class="text-xs md:text-sm text-gray-700">Ground yourself by identifying 5 things you see, 4 you feel, 3 you hear, 2 you smell, and 1 you taste.</span>
                    </li>
                </ul>
            </div>

            <!-- Study Efficiency -->
            <div class="bg-white p-6 md:p-8 rounded-3xl border border-secondary/20 shadow-lg">
                <h3 class="text-lg md:text-xl font-black mb-6 text-primary flex items-center gap-2">
                    <span class="p-2 bg-secondary/10 rounded-lg">📖</span> Study Efficiency
                </h3>
                <ul class="space-y-4">
                    <li class="bg-bgmain/30 p-4 rounded-xl border border-secondary/10">
                        <strong class="block text-primary text-sm md:text-base">Active Recall</strong>
                        <span class="text-xs md:text-sm text-gray-700">Test yourself before you study. It primes your brain to retain the information better.</span>
                    </li>
                    <li class="bg-bgmain/30 p-4 rounded-xl border border-secondary/10">
                        <strong class="block text-primary text-sm md:text-base">Time Blocking</strong>
                        <span class="text-xs md:text-sm text-gray-700">Dedicate specific blocks of time to one subject only. No multitasking allowed.</span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Emergency / Crisis Override -->
        <div class="bg-primary text-white p-8 md:p-10 rounded-3xl shadow-2xl text-center border-t-8 border-secondary">
            <h3 class="text-xl md:text-2xl font-black mb-4">Feeling Overwhelmed?</h3>
            <p class="mb-8 text-bgmain text-base md:text-lg font-medium opacity-90">If you're feeling like you can't handle things anymore, please reach out. You are not alone.</p>
            <div class="flex flex-col sm:flex-row justify-center gap-4">
                <a href="https://web.facebook.com/profile.php?id=61579587254479" target="_blank" class="px-8 py-3 bg-bgmain text-primary rounded-xl font-black hover:scale-105 transition shadow-lg w-full sm:w-auto inline-block">Talk to a Counselor Now</a>
                <div class="w-full sm:w-auto px-8 py-3 bg-white/10 text-white rounded-xl font-black border border-white/20 backdrop-blur-sm text-sm md:text-base">Crisis Text Line: Text HOME to 09356803499</div>
            </div>
            <p class="mt-6 text-[10px] md:text-sm text-bgmain opacity-80 italic font-medium">* This will notify your school counselor and prioritize your support request.</p>
        </div>
    </main>

    <script>
        const texts = ["Breathe In", "Hold", "Breathe Out", "Hold"];
        let i = 0;
        setInterval(() => {
            i = (i + 1) % texts.length;
            document.getElementById('breatheText').innerText = texts[i];
        }, 2000);
    </script>
</body>
</html>
