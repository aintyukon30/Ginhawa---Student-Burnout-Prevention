<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Counselor Dashboard | Ginhawa</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen">
    <nav class="p-4 bg-white shadow-sm flex justify-between items-center px-8">
        <div class="text-xl font-bold text-blue-600">Ginhawa <span class="text-gray-400 text-sm font-normal">| Counselor Portal</span></div>
        <div class="flex items-center gap-6">
            <div class="flex items-center gap-2">
                <span class="text-gray-700 font-medium"><%= user.email %></span>
                <a href="/logout" class="text-sm text-red-500">Logout</a>
            </div>
        </div>
    </nav>

    <main class="p-8 max-w-6xl mx-auto">
        <div class="mb-8 flex justify-between items-end">
            <div>
                <h2 class="text-3xl font-bold">Student Risk Monitoring</h2>
                <p class="text-gray-600">Anonymized view of student burnout patterns for early intervention.</p>
            </div>
            <div class="flex gap-4">
                <button class="px-4 py-2 bg-white border rounded-lg shadow-sm text-sm font-bold hover:bg-gray-50">Export Report (PDF)</button>
                <button class="px-4 py-2 bg-blue-600 text-white rounded-lg shadow-sm text-sm font-bold hover:bg-blue-700">Send Bulk Alert</button>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border overflow-hidden">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50 border-b">
                        <th class="p-4 font-bold text-gray-500 uppercase text-xs tracking-wider">Student ID (Encrypted)</th>
                        <th class="p-4 font-bold text-gray-500 uppercase text-xs tracking-wider">Risk Level</th>
                        <th class="p-4 font-bold text-gray-500 uppercase text-xs tracking-wider">Recent Metrics</th>
                        <th class="p-4 font-bold text-gray-500 uppercase text-xs tracking-wider">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (students.length === 0) { %>
                        <tr>
                            <td colspan="4" class="p-8 text-center text-gray-500">No students registered in the system yet.</td>
                        </tr>
                    <% } %>
                    <% students.forEach(s => { %>
                        <tr class="border-b hover:bg-gray-50 transition">
                            <td class="p-4 font-mono text-sm text-gray-600">USR-<%= s.id.toString().padStart(4, '0') %></td>
                            <td class="p-4">
                                <span class="px-3 py-1 rounded-full text-xs font-bold uppercase <%= s.riskColor %> bg-opacity-10 border" style="background-color: currentColor; border-color: currentColor;">
                                    <span class="text-gray-900"><%= s.riskLevel %></span>
                                </span>
                            </td>
                            <td class="p-4 text-sm text-gray-600">
                                <% if (s.last_sleep) { %>
                                    Sleep: <%= s.last_sleep %>h | Study: <%= s.last_study %>h | Stress: <%= s.last_stress %>/5
                                <% } else { %>
                                    No data yet
                                <% } %>
                            </td>
                            <td class="p-4">
                                <button class="text-blue-600 font-bold text-sm hover:underline">Message Support</button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <!-- Alert Panel -->
        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="bg-red-50 border border-red-100 p-6 rounded-2xl">
                <h3 class="text-red-800 font-bold mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    High Risk Alerts
                </h3>
                <% const highRisk = students.filter(s => s.riskLevel === 'High').length; %>
                <p class="text-red-700 text-sm mb-4">You have <strong><%= highRisk %></strong> students in the high burnout risk category. It is recommended to initiate a 1:1 check-in.</p>
                <button class="text-red-700 text-xs font-bold uppercase tracking-widest hover:underline">Review All High Risk Students &rarr;</button>
            </div>
            <div class="bg-blue-50 border border-blue-100 p-6 rounded-2xl">
                <h3 class="text-blue-800 font-bold mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Suggested Actions
                </h3>
                <ul class="text-blue-700 text-sm space-y-2">
                    <li>• Schedule "Wellness Wednesday" workshop</li>
                    <li>• Send class-wide reminder about extension policies</li>
                    <li>• Distribute "Active Recall" study guide</li>
                </ul>
            </div>
        </div>
    </main>
</body>
</html>
