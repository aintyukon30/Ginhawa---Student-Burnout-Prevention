<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Counselor Dashboard | Ginhawa</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Ephesis&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#346739',
                        secondary: '#79AE6F',
                        bgmain: '#F2EDC2',
                    },
                    fontFamily: {
                        title: ['Ephesis', 'cursive'],
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-bgmain min-h-screen text-black">
    <nav class="p-4 bg-white/50 backdrop-blur-md shadow-sm flex justify-between items-center px-8 border-b border-secondary/20">
        <div class="text-3xl font-bold text-primary font-title flex items-center gap-2">Ginhawa <span class="text-secondary text-sm font-black font-sans">| Counselor Portal</span></div>
        <div class="flex items-center gap-6">
            <div class="flex items-center gap-2">
                <span class="text-gray-800 font-bold"><%= user.email %></span>
                <a href="/logout" class="text-sm text-red-600 font-bold hover:underline">Logout</a>
            </div>
        </div>
    </nav>

    <main class="p-8 max-w-6xl mx-auto">
        <div class="mb-8 flex justify-between items-end">
            <div>
                <h2 class="text-3xl font-black text-primary">Student Risk Monitoring</h2>
                <p class="text-gray-700 font-medium">Anonymized view of student burnout patterns for early intervention.</p>
            </div>
            <div class="flex gap-4">
                <button class="px-4 py-2 bg-white border border-secondary/30 rounded-lg shadow-sm text-sm font-bold hover:bg-bgmain transition">Export Report (PDF)</button>
                <button class="px-4 py-2 bg-primary text-white rounded-lg shadow-sm text-sm font-bold hover:opacity-90 transition">Send Bulk Alert</button>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-xl border border-secondary/20 overflow-hidden">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-secondary/10 border-b border-secondary/20">
                        <th class="p-4 font-black text-primary uppercase text-xs tracking-widest">Student ID (Encrypted)</th>
                        <th class="p-4 font-black text-primary uppercase text-xs tracking-widest">Risk Level</th>
                        <th class="p-4 font-black text-primary uppercase text-xs tracking-widest">Recent Metrics</th>
                        <th class="p-4 font-black text-primary uppercase text-xs tracking-widest">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (students.length === 0) { %>
                        <tr>
                            <td colspan="4" class="p-8 text-center text-gray-500 font-medium italic">No students registered in the system yet.</td>
                        </tr>
                    <% } %>
                    <% students.forEach(s => { %>
                        <tr class="border-b border-secondary/10 hover:bg-bgmain/50 transition">
                            <td class="p-4 font-mono text-sm text-gray-700">USR-<%= s.id.toString().padStart(4, '0') %></td>
                            <td class="p-4">
                                <span class="px-3 py-1 rounded-full text-xs font-black uppercase <%= s.riskLevel === 'Low' ? 'text-primary bg-primary/10' : (s.riskLevel === 'Moderate' ? 'text-secondary bg-secondary/10' : 'text-red-700 bg-red-50') %> border border-current">
                                    <%= s.riskLevel %>
                                </span>
                            </td>
                            <td class="p-4 text-sm text-gray-700 font-medium">
                                <% if (s.last_sleep) { %>
                                    Sleep: <%= s.last_sleep %>h | Study: <%= s.last_study %>h | Stress: <%= s.last_stress %>/5
                                <% } else { %>
                                    No data yet
                                <% } %>
                            </td>
                            <td class="p-4">
                                <button class="text-primary font-black text-sm hover:underline">Message Support</button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <!-- Alert Panel -->
        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="bg-white p-6 rounded-2xl shadow-lg border-l-8 border-red-500">
                <h3 class="text-red-800 font-black mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    High Risk Alerts
                </h3>
                <% const highRisk = students.filter(s => s.riskLevel === 'High').length; %>
                <p class="text-gray-800 text-sm mb-4 font-medium">You have <strong><%= highRisk %></strong> students in the high burnout risk category. It is recommended to initiate a 1:1 check-in.</p>
                <button class="text-red-700 text-xs font-black uppercase tracking-widest hover:underline">Review All High Risk Students &rarr;</button>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-lg border-l-8 border-primary">
                <h3 class="text-primary font-black mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Suggested Actions
                </h3>
                <ul class="text-gray-800 text-sm space-y-2 font-medium">
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-secondary rounded-full"></span> Schedule "Wellness Wednesday" workshop</li>
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-secondary rounded-full"></span> Send class-wide reminder about extension policies</li>
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-secondary rounded-full"></span> Distribute "Active Recall" study guide</li>
                </ul>
            </div>
        </div>
    </main>
</body>
</html>
