<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Onboarding | Ginhawa</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Ephesis&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#346739',
                        secondary: '#79AE6F',
                        bgmain: '#DED79E',
                    },
                    fontFamily: {
                        title: ['Ephesis', 'cursive'],
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-bgmain flex items-center justify-center min-h-screen text-black p-4 md:p-6">
    <div class="bg-white p-6 md:p-8 rounded-2xl shadow-xl w-full max-w-lg border border-secondary/20 my-auto">
        <h2 class="text-5xl font-bold mb-4 text-primary font-title text-center">Ginhawa</h2>
        <p class="text-gray-700 mb-8 font-medium text-center">Let's get some baseline data to help our AI understand your current state. We only use this to detect burnout patterns – your data is never sold.</p>
        
        <form action="/onboarding" method="POST">
            <div class="mb-6">
                <label class="block font-bold mb-2 text-gray-800">Daily Sleep (Avg hours)</label>
                <input type="number" step="0.5" name="sleep" required class="w-full p-3 border border-secondary/30 rounded-lg focus:ring-2 focus:ring-primary outline-none transition" placeholder="e.g. 7.5">
            </div>
            <div class="mb-6">
                <label class="block font-bold mb-2 text-gray-800">Daily Study (Avg hours)</label>
                <input type="number" step="0.5" name="study" required class="w-full p-3 border border-secondary/30 rounded-lg focus:ring-2 focus:ring-primary outline-none transition" placeholder="e.g. 5">
            </div>
            <div class="mb-8">
                <label class="block font-bold mb-2 text-gray-800">Stress Level (1-5)</label>
                <div class="flex justify-between gap-2">
                    <label class="flex-1 text-center cursor-pointer">
                        <input type="radio" name="stress" value="1" required class="block mx-auto mb-1 accent-primary"> 1<br><small class="font-bold text-secondary">Low</small>
                    </label>
                    <label class="flex-1 text-center cursor-pointer">
                        <input type="radio" name="stress" value="2" class="block mx-auto mb-1 accent-primary"> 2
                    </label>
                    <label class="flex-1 text-center cursor-pointer">
                        <input type="radio" name="stress" value="3" class="block mx-auto mb-1 accent-primary"> 3
                    </label>
                    <label class="flex-1 text-center cursor-pointer">
                        <input type="radio" name="stress" value="4" class="block mx-auto mb-1 accent-primary"> 4
                    </label>
                    <label class="flex-1 text-center cursor-pointer">
                        <input type="radio" name="stress" value="5" class="block mx-auto mb-1 accent-primary"> 5<br><small class="font-bold text-red-600">High</small>
                    </label>
                </div>
            </div>
            <button type="submit" class="w-full bg-primary text-white p-4 rounded-xl font-bold text-lg hover:opacity-90 transition shadow-md">Complete Setup</button>
        </form>
    </div>
</body>
</html>
