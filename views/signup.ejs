<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Signup | Ginhawa</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Ephesis&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#346739',
                        secondary: '#79AE6F',
                        bgmain: '#F2EDC2',
                    },
                    fontFamily: {
                        title: ['Ephesis', 'cursive'],
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-bgmain flex items-center justify-center min-h-screen text-black">
    <div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-md border border-secondary/20">
        <h2 class="text-4xl font-bold mb-6 text-center text-primary font-title">Ginhawa</h2>
        <% if (error) { %>
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm font-medium"><%= error %></div>
        <% } %>
        <form action="/signup" method="POST">
            <div class="mb-4">
                <label class="block text-gray-700 mb-2 font-medium">I am a...</label>
                <div class="flex gap-4">
                    <label class="flex-1 border border-secondary/30 p-3 rounded-lg cursor-pointer hover:bg-bgmain transition text-center">
                        <input type="radio" name="role" value="student" class="hidden peer" checked>
                        <span class="peer-checked:text-primary peer-checked:font-bold">Student</span>
                    </label>
                    <label class="flex-1 border border-secondary/30 p-3 rounded-lg cursor-pointer hover:bg-bgmain transition text-center">
                        <input type="radio" name="role" value="counselor" class="hidden peer">
                        <span class="peer-checked:text-primary peer-checked:font-bold">Counselor</span>
                    </label>
                </div>
            </div>
            <div class="mb-4">
                <label class="block text-gray-700 mb-2 font-medium">Email</label>
                <input type="email" name="email" required class="w-full p-3 border border-secondary/30 rounded-lg focus:ring-2 focus:ring-primary outline-none transition">
            </div>
            <div class="mb-4">
                <label class="block text-gray-700 mb-2 font-medium">Password</label>
                <input type="password" name="password" required class="w-full p-3 border border-secondary/30 rounded-lg focus:ring-2 focus:ring-primary outline-none transition">
            </div>
            <div class="mb-6" id="schoolCodeGroup">
                <label class="block text-gray-700 mb-2 font-medium">School Code (Optional)</label>
                <input type="text" name="school_code" class="w-full p-3 border border-secondary/30 rounded-lg focus:ring-2 focus:ring-primary outline-none transition">
            </div>
            <button type="submit" class="w-full bg-primary text-white p-3 rounded-lg font-bold hover:opacity-90 transition shadow-md">Sign Up</button>
        </form>
        <script>
            const roleRadios = document.querySelectorAll('input[name="role"]');
            const schoolCodeGroup = document.getElementById('schoolCodeGroup');

            roleRadios.forEach(radio => {
                radio.addEventListener('change', (e) => {
                    if (e.target.value === 'counselor') {
                        schoolCodeGroup.classList.add('hidden');
                    } else {
                        schoolCodeGroup.classList.remove('hidden');
                    }
                });
            });
        </script>
        <p class="mt-4 text-center text-gray-700 font-medium text-sm">Already have an account? <a href="/login" class="text-primary font-bold hover:underline">Login</a></p>
    </div>
</body>
</html>
