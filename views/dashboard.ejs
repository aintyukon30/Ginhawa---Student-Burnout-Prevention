<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard | Ginhawa</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-gray-100 min-h-screen">
    <nav class="p-4 bg-white shadow-sm flex justify-between items-center px-8">
        <div class="text-xl font-bold text-blue-600">Ginhawa</div>
        <div class="flex items-center gap-6">
            <a href="/wellness" class="text-gray-600 hover:text-blue-600 font-medium">Wellness Toolkit</a>
            <button id="breakBtn" class="px-4 py-2 bg-purple-100 text-purple-700 rounded-lg font-bold hover:bg-purple-200 transition">Take a Break</button>
            <div class="flex items-center gap-2">
                <span class="text-gray-700 font-medium"><%= user.email %></span>
                <a href="/logout" class="text-sm text-red-500">Logout</a>
            </div>
        </div>
    </nav>

    <!-- Take a Break Overlay -->
    <div id="breakOverlay" class="fixed inset-0 bg-purple-900 bg-opacity-95 z-50 hidden flex flex-center items-center justify-center text-center p-8">
        <div class="max-w-lg">
            <h2 class="text-4xl font-bold text-white mb-6">Time to breathe...</h2>
            <div class="w-32 h-32 border-8 border-white border-t-transparent rounded-full animate-spin mx-auto mb-8"></div>
            <p class="text-purple-200 text-xl mb-8">Take 5 minutes for yourself. Your grades will be here when you get back.</p>
            <button id="resumeBtn" class="px-8 py-3 bg-white text-purple-900 rounded-xl font-bold text-lg">Back to Dashboard</button>
        </div>
    </div>

    <main class="p-8 max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- LEFT COL: RISK & PULSE -->
        <div class="lg:col-span-2 space-y-8">
            <!-- Burnout Risk Indicator -->
            <div class="bg-white p-6 rounded-2xl shadow-sm border">
                <h3 class="text-lg font-bold text-gray-500 mb-4 uppercase tracking-wider">Burnout Risk Indicator</h3>
                <div class="flex items-center justify-between">
                    <div>
                        <div class="text-5xl font-black <%= risk.color %>"><%= risk.level %></div>
                        <p class="text-gray-500 mt-2">Based on your recent patterns</p>
                    </div>
                    <div class="text-right">
                        <% if (risk.reasons.length > 0) { %>
                            <ul class="text-sm text-gray-600">
                                <% risk.reasons.forEach(r => { %>
                                    <li class="flex items-center justify-end gap-2">
                                        <span><%= r %></span>
                                        <span class="w-2 h-2 bg-red-400 rounded-full"></span>
                                    </li>
                                <% }) %>
                            </ul>
                        <% } else { %>
                            <p class="text-green-500 font-bold">Patterns looking healthy! ✨</p>
                        <% } %>
                    </div>
                </div>
                <div class="mt-6 w-full bg-gray-200 h-4 rounded-full overflow-hidden">
                    <div class="h-full bg-blue-500 transition-all duration-1000" style="width: <%= risk.score %>%"></div>
                </div>
            </div>

            <!-- Academic Pulse -->
            <div class="bg-white p-6 rounded-2xl shadow-sm border" id="academicPulse">
                <h3 class="text-lg font-bold text-gray-500 mb-4 uppercase tracking-wider">Academic Pulse (Weekly View)</h3>
                <canvas id="gradeChart" height="150"></canvas>
            </div>
        </div>

        <!-- RIGHT COL: HABITS & RECS -->
        <div class="space-y-8">
            <!-- Personalized Recommendations -->
            <div class="bg-blue-600 text-white p-6 rounded-2xl shadow-lg">
                <h3 class="text-lg font-bold mb-4">AI Recommendations</h3>
                <div class="space-y-4">
                    <% if (risk.level === 'High') { %>
                        <div class="bg-white/10 p-4 rounded-xl border border-white/20">
                            <p class="font-bold mb-1">Critical Rest Needed</p>
                            <p class="text-sm opacity-90">Your sleep has been below 6h for 3 days. Try this 10-min wind-down routine.</p>
                            <button class="mt-3 text-sm font-bold underline">View Routine</button>
                        </div>
                    <% } %>
                    <div class="bg-white/10 p-4 rounded-xl border border-white/20">
                        <p class="font-bold mb-1">Study Tip</p>
                        <p class="text-sm opacity-90">Your average study session: 3.2h without break. Try the 25/5 Pomodoro method today.</p>
                    </div>
                </div>
            </div>

            <!-- Habit Tracker Form -->
            <div class="bg-white p-6 rounded-2xl shadow-sm border">
                <h3 class="text-lg font-bold text-gray-500 mb-4 uppercase tracking-wider">Log Today's Metrics</h3>
                <form action="/api/metrics" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-sm font-bold text-gray-700">Sleep Hours</label>
                        <input type="number" step="0.5" name="sleep" required class="w-full mt-1 p-2 border rounded-lg bg-gray-50">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700">Study Hours</label>
                        <input type="number" step="0.5" name="study" required class="w-full mt-1 p-2 border rounded-lg bg-gray-50">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700">Stress Level (1-5)</label>
                        <input type="range" name="stress" min="1" max="5" class="w-full mt-2">
                    </div>
                    <button type="submit" class="w-full py-2 bg-blue-600 text-white rounded-lg font-bold">Save Metrics</button>
                </form>
            </div>

            <!-- Grade Entry -->
            <div class="bg-white p-6 rounded-2xl shadow-sm border">
                <h3 class="text-lg font-bold text-gray-500 mb-4 uppercase tracking-wider">New Grade</h3>
                <form action="/api/grades" method="POST" class="space-y-4">
                    <input type="text" name="subject" placeholder="Subject" required class="w-full p-2 border rounded-lg bg-gray-50">
                    <input type="number" name="score" placeholder="Score (0-100)" required class="w-full p-2 border rounded-lg bg-gray-50">
                    <button type="submit" class="w-full py-2 border border-blue-600 text-blue-600 rounded-lg font-bold">Add Grade</button>
                </form>
            </div>
        </div>
    </main>

    <script>
        // Chart.js implementation
        const ctx = document.getElementById('gradeChart').getContext('2d');
        const grades = <%- JSON.stringify(grades.reverse()) %>;
        
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: grades.map(g => g.subject),
                datasets: [{
                    label: 'Grade Score',
                    data: grades.map(g => g.score),
                    borderColor: '#2563eb',
                    tension: 0.3,
                    fill: true,
                    backgroundColor: 'rgba(37, 99, 235, 0.1)'
                }]
            },
            options: {
                scales: {
                    y: { beginAtZero: true, max: 100 }
                }
            }
        });

        // Take a Break Mode
        const breakBtn = document.getElementById('breakBtn');
        const resumeBtn = document.getElementById('resumeBtn');
        const breakOverlay = document.getElementById('breakOverlay');

        breakBtn.addEventListener('click', () => {
            breakOverlay.classList.remove('hidden');
            breakOverlay.classList.add('flex');
            document.body.style.overflow = 'hidden';
        });

        resumeBtn.addEventListener('click', () => {
            breakOverlay.classList.add('hidden');
            breakOverlay.classList.remove('flex');
            document.body.style.overflow = 'auto';
        });
    </script>
</body>
</html>
